<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Sinedrio Danai — Solemn Dark Theme -->
    <style name="Theme.SinedrioDanai" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary: ceremonial gold -->
        <item name="colorPrimary">@color/sinedrio_gold</item>
        <item name="colorPrimaryVariant">@color/sinedrio_gold_dark</item>
        <item name="colorOnPrimary">@color/sinedrio_background</item>

        <!-- Secondary: deep purple -->
        <item name="colorSecondary">@color/sinedrio_purple_light</item>
        <item name="colorSecondaryVariant">@color/sinedrio_purple</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Backgrounds and surfaces -->
        <item name="android:colorBackground">@color/sinedrio_background</item>
        <item name="colorSurface">@color/sinedrio_surface</item>
        <item name="colorOnSurface">@color/sinedrio_text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/sinedrio_background</item>
        <item name="android:navigationBarColor">@color/sinedrio_background</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/sinedrio_text_primary</item>
        <item name="android:textColorSecondary">@color/sinedrio_text_secondary</item>
    </style>
</resources>
